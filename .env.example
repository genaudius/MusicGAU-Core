# Renombra este archivo a .env y coloca tus credenciales reales.
# NUNCA subas el archivo .env a GitHub.

# Credenciales de Cloudflare R2
# El Account ID lo encuentras en la URL de tu dashboard de R2 o en la página principal de R2
R2_ACCOUNT_ID="pon_tu_account_id_aqui"

# Genera un token en la sección "Manage R2 API Tokens" con permisos de "Edit"
R2_ACCESS_KEY="pon_tu_access_key_aqui"
R2_SECRET_KEY="pon_tu_secret_key_aqui"

# El nombre del bucket que creaste en Cloudflare R2
R2_BUCKET_NAME="pon_el_nombre_del_bucket_aqui"
